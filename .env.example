# Memory OS — secrets and host overrides.
# Service hosts/ports/model names live in config/services.yaml.
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Postgres (NAS) ────────────────────────────────────
POSTGRES_USER_NAME=postgres
POSTGRES_USER_PASSWORD=asdf
POSTGRES_IP=192.168.1.134
POSTGRES_PORT=5432
POSTGRES_DB=memos

# ── Valkey (Redis-compatible, NAS) ────────────────────
VALKEY_IP=192.168.1.134
VALKEY_PORT=6389
VALKEY_PASSWORD=               # empty OK on a trusted LAN

# ── Qdrant (NAS) ──────────────────────────────────────
QDRANT_URL=http://192.168.1.135:6333
QDRANT_HOST=192.168.1.135
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge_base

# ── LiteLLM (embedding + chat + extraction) ───────────
LITELLM_URL=https://litellm.airmonitor.pl/v1
LITELLM_API_KEY=sk-...
EMBEDDING_MODEL=rapid-mlx-qwen3-embedding-8b
EMBEDDING_DIMENSIONS=4096
EMBEDDING_CONTEXT_LENGTH=32768
CHAT_MODEL=lm-studio-qwen3.6
EXTRACTION_MODEL=lm-studio-qwen3.6
ICARUS_EXTRACTION_MAX_TOKENS=4096

# ── Paths (host-side; written into config.paths) ──────
HERMES_HOME=/home/your-user/.hermes
STATE_DB_PATH=/home/your-user/.hermes/state.db
MEMORY_STORE_DB=/home/your-user/.hermes/memory_store.db
FABRIC_DIR=/home/your-user/vault/fabric
VAULT_PATH=/home/your-user/vault
WIKI_ROOT=/home/your-user/vault/wiki
TELEMETRY_LOG_PATH=/home/your-user/.hermes/logs/query-telemetry.jsonl
REFLECTION_LOG_PATH=/home/your-user/.hermes/logs/reflection_trigger.log

# ── Optional ──────────────────────────────────────────
# CONFIG_PATH=/absolute/path/to/config/services.yaml
# LOG_LEVEL=INFO
# WIKI_PATH=/wiki                       # worker container mount target
